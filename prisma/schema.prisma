// Prisma schema for the AI News Hub

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SourceType {
  rss
  html
  api
  youtube
}

enum TrustTier {
  official_vendor
  reputed_press
  research_university
  influencer
}

enum ItemType {
  article
  video
  paper
  release
}

enum IngestionStatus {
  running
  success
  partial
  failed
}

model Source {
  id        String     @id @default(cuid())
  name      String
  type      SourceType
  url       String
  trustTier TrustTier
  enabled   Boolean    @default(true)
  tags      String[]   @default([])
  htmlSelector String?
  channelId    String?
  consecutiveFailures Int @default(0)
  degradedUntil       DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     Item[]

  @@index([enabled])
  @@index([type])
}

model Item {
  id             String   @id @default(cuid())
  sourceId       String
  source         Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  title          String
  url            String
  publishedAt    DateTime @default(now())
  author         String?
  summary        String?  @db.VarChar(500)
  contentSnippet String?  @db.Text
  type           ItemType @default(article)
  topics         String[] @default([])
  thumbnailUrl   String?
  canonicalHash  String   @unique
  language       String   @default("en")
  metricsViews   Int      @default(0)
  metricsLikes   Int      @default(0)
  rawPayload     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  videoMeta  VideoMeta?
  curations  ManualCuration[]

  @@index([sourceId])
  @@index([publishedAt(sort: Desc)])
  @@index([type])
  @@index([canonicalHash])
}

model VideoMeta {
  id          String  @id @default(cuid())
  itemId      String  @unique
  item        Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  channelName String?
  channelId   String?
  videoId     String
  duration    String?
  transcript  String? @db.Text
}

model ManualCuration {
  id        String    @id @default(cuid())
  itemId    String
  item      Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  pinned    Boolean   @default(false)
  note      String?
  priority  Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([pinned])
  @@index([itemId])
}

model IngestionRun {
  id         String          @id @default(cuid())
  startedAt  DateTime        @default(now())
  finishedAt DateTime?
  status     IngestionStatus @default(running)
  stats      Json?
  errors     Json?
  sourceId   String?
  createdAt  DateTime        @default(now())

  @@index([status])
  @@index([startedAt(sort: Desc)])
}
