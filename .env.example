# Database (PostgreSQL - e.g. Neon, Supabase, or local)
DATABASE_URL="postgresql://user:password@localhost:5432/ai_news_hub?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/ai_news_hub?schema=public"

# Admin authentication (used by /api/ingest, /api/admin/*, /api/ingestion POST)
ADMIN_TOKEN="change-me-to-a-secure-random-string"

# Cron authentication (used by /api/cron/ingest-hourly and /api/cron/ingest-daily)
# Pass as ?secret=<value> or Authorization: Bearer <value>
CRON_SECRET="change-me-to-a-secure-random-string"

# Ingestion settings
INGESTION_INTERVAL_MINUTES=120
MAX_RETRIES=3
BACKOFF_MULTIPLIER=2

# Feature flags
ENABLE_LLM_TOPICS=false

# Optional: OpenAI for LLM topic tagging (only used if ENABLE_LLM_TOPICS=true)
OPENAI_API_KEY=""

# App URL (for CORS / absolute URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Logging
LOG_LEVEL="info"
