{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "next.config.js",
      "use": "@vercel/next"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/ingest-hourly",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/ingest-daily",
      "schedule": "15 2 * * *"
    }
  ]
}
